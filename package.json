{
  "name": "echoboard",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "db:generate": "npm run db:generate -w @workspace/db",
    "db:migrate": "npm run db:migrate -w @workspace/db",
    "db:push": "npm run db:push -w @workspace/db",
    "db:studio": "npm run db:studio -w @workspace/db",
    "auth:generate": "npm run auth:generate -w @workspace/auth"
  },
  "devDependencies": {
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
