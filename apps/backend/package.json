    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workspace/auth": "*",
    "@workspace/db": "*",
    "better-auth": "^1.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "tsx": "^4.19.2",
    "ws": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.1.0",
    "@types/ws": "^8.18.1",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "eslint": "^9.39.2",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.9.3"
