# URL of the Express backend that hosts /api/auth/*. In dev this is the port
# apps/backend listens on (default 4000).
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Toggles the "Continue with Google" button between active and disabled.
# Set to "true" only once GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET are filled
# in on the backend and the callback URL is registered in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_ENABLED=false
